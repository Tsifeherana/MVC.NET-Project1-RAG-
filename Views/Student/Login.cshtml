@model Projet1.ViewModels.LoginViewModel

@{
    ViewData["Title"] = "Login";
}

<section class="auth-page">
    <div class="auth-card">
        <div class="auth-card__header">
            <span class="auth-badge">Connexion</span>
            <h1>Content de te revoir</h1>
            <p>Connecte-toi pour continuer vers ton espace étudiant.</p>
        </div>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-danger rounded-4 border-0 shadow-sm" role="alert">
                @Html.ValidationSummary(false)
            </div>
        }

        <form asp-action="Login" asp-controller="Student" method="post" class="auth-form">
            <div class="mb-3">
                <label asp-for="Mail" class="form-label">Adresse e-mail</label>
                <input asp-for="Mail" class="form-control form-control-lg auth-input" placeholder="exemple@mail.com" required/>
                <span asp-validation-for="Mail" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Password" class="form-label">Mot de passe</label>
                <input asp-for="Password" type="password" class="form-control form-control-lg auth-input" placeholder="••••••••" required/>
                <span asp-validation-for="Password" class="text-danger small"></span>
            </div>

            <button type="submit" class="btn btn-primary btn-lg w-100 auth-btn">Se connecter</button>
        </form>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
